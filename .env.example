# ==============================================
# ClawManager Docker Compose - 环境变量配置
# ==============================================
# 复制本文件为 .env，然后修改对应值
# cp .env.example .env

# ------------------
# MySQL 配置
# ------------------
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=clawmanager
MYSQL_USER=clawreef
MYSQL_PASSWORD=clawreef123

# MySQL 数据持久化路径（宿主机路径）
MYSQL_DATA_PATH=/mnt/Storage1/clawmanager/mysql

# ------------------
# MinIO 配置
# ------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO 数据持久化路径（宿主机路径）
MINIO_DATA_PATH=/mnt/Storage1/clawmanager/minio

# ------------------
# ClawManager 应用配置
# ------------------
# 主应用端口（宿主机映射端口）
APP_PORT=30443

# Skill Scanner 端口
SKILL_SCANNER_PORT=8000

# ------------------
# 网络配置
# ------------------
# Docker 网络名称
NETWORK_NAME=clawmanager-net

# Docker 网络网段（可选，默认由 Docker 分配）
# NETWORK_SUBNET=172.22.0.0/16
